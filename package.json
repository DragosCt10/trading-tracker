    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-date-range": "^1.4.10",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
