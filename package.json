{
  "name": "trading-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:new": "prisma migrate dev --create-only --name",
    "db:migrate:create": "prisma migrate diff --from-schema-datasource prisma/schema.prisma --to-schema-datamodel prisma/schema.prisma --script",
    "db:types:test": "supabase gen types typescript --project-id vjzhqacouosiopedktat --schema public > src/types/supabase.ts",
    "db:types:prod": "supabase gen types typescript --project-id obgexglqwdzgvwzppwfx --schema public > src/types/supabase.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench tests/benchmark --reporter=verbose --run",
    "bench:ci": "vitest bench tests/benchmark --reporter=json --outputFile=tests/benchmark/results/latest.json --run",
    "test:responsive": "playwright test tests/e2e/responsive/ --workers=4",
    "test:responsive:update": "playwright test tests/e2e/responsive/ --update-snapshots --workers=4"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@next/third-parties": "^16.2.4",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "fuzzball": "^2.2.3",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-date-range": "^2.0.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.5",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
