  is_banned       Boolean   @default(false)
  ban_log         Json?
  follower_count  Int       @default(0)
  following_count Int       @default(0)
  /// Denormalized from subscriptions. Updated by subscription server actions.
  tier            String    @default("starter") @db.VarChar(20)
  /// Denormalized highest trade milestone badge (e.g. 'rookie_trader').
  trade_badge     String?   @db.VarChar(30)
  /// Self-declared trading style (e.g. 'Scalper', 'Day trader', or custom).
  trader_style    String?   @db.VarChar(50)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)

  users                    users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  feed_posts               feed_posts[]
  feed_comments            feed_comments[]
  feed_likes               feed_likes[]
  follows_follower         follows[]              @relation("follows_follower")
  follows_following        follows[]              @relation("follows_following")
  feed_notifications_recipient feed_notifications[] @relation("notifications_recipient")
  feed_notifications_actor feed_notifications[]   @relation("notifications_actor")
  feed_channels            feed_channels[]
  channel_members          channel_members[]
  channel_public_removed_members channel_public_removed_members[]
  feed_reports             feed_reports[]

  @@index([username])
  @@index([user_id])
  @@schema("public")
}

/// Posts in the social feed.
model feed_posts {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_id      String    @db.Uuid
  content        String
  post_type      post_type @default(text)
  /// Original trade ID — for reference only. Display uses trade_snapshot.
  trade_id       String?   @db.Uuid
  trade_mode     String?   @db.VarChar(20)
  /// Denormalized trade data snapshotted at post time. Never joins trade tables.
  trade_snapshot Json?
  channel_id     String?   @db.Uuid
  like_count     Int       @default(0)
  comment_count  Int       @default(0)
  is_hidden      Boolean   @default(false)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  author           social_profiles    @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  channel          feed_channels?     @relation(fields: [channel_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  feed_comments    feed_comments[]
  feed_likes       feed_likes[]
  feed_notifications feed_notifications[]
  feed_reports     feed_reports[]

  @@index([author_id, created_at(sort: Desc)], map: "idx_feed_posts_author_created")
  @@index([channel_id, created_at(sort: Desc)], map: "idx_feed_posts_channel_created")
  @@index([created_at(sort: Desc)], map: "idx_feed_posts_created")
  @@index([is_hidden, created_at(sort: Desc)], map: "idx_feed_posts_hidden_created")
  @@schema("public")
}

/// Comments on feed posts (1-level nested replies via parent_id).
model feed_comments {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id     String   @db.Uuid
  author_id   String   @db.Uuid
