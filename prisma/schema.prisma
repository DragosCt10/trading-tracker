  is_hidden   Boolean  @default(false)
  reply_count Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  post              feed_posts      @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  author            social_profiles @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent            feed_comments?  @relation("comment_replies", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies           feed_comments[] @relation("comment_replies")
  feed_reports      feed_reports[]

  @@index([post_id, created_at(sort: Asc)], map: "idx_feed_comments_post_created")
  @@schema("public")
}

