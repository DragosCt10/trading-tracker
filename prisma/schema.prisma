  follower_id  String   @db.Uuid
  following_id String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  follower  social_profiles @relation("follows_follower",  fields: [follower_id],  references: [id], onDelete: Cascade, onUpdate: NoAction)
  following social_profiles @relation("follows_following", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([follower_id, following_id])
  @@index([follower_id],  map: "idx_follows_follower")
  @@index([following_id], map: "idx_follows_following")
  @@schema("public")
}

/// Activity notifications (like, comment, follow only — no new_post fanout).
model feed_notifications {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipient_id String            @db.Uuid
  actor_id     String            @db.Uuid
  type         notification_type
  post_id      String?           @db.Uuid
  comment_id   String?           @db.Uuid
  is_read      Boolean           @default(false)
  created_at   DateTime          @default(now()) @db.Timestamptz(6)

  recipient social_profiles  @relation("notifications_recipient", fields: [recipient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  actor     social_profiles  @relation("notifications_actor",     fields: [actor_id],     references: [id], onDelete: Cascade, onUpdate: NoAction)
  post      feed_posts?      @relation(fields: [post_id],    references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([recipient_id, is_read, created_at(sort: Desc)], map: "idx_feed_notifications_recipient")
  // Composite index for batch milestone-type lookups (checkTradeMilestones .in() query)
  @@index([recipient_id, type], map: "idx_feed_notifications_recipient_type")
  // Partial unique index on offer types is managed via raw SQL migration
  // (feed_notifications_offer_unique) — Prisma does not support WHERE on @@unique
  @@schema("public")
}

/// PRO-only private channels.
model feed_channels {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id    String   @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(500)
  logo_url    String?  @db.VarChar(500)
  is_public   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  owner           social_profiles   @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  feed_posts       feed_posts[]
  channel_members  channel_members[]
  channel_invites  channel_invites[]
  channel_public_removed_members channel_public_removed_members[]

  @@index([owner_id], map: "idx_feed_channels_owner")
  @@schema("public")
}

/// Channel membership.
model channel_members {
  channel_id String   @db.Uuid
  user_id    String   @db.Uuid
  role       String   @default("member") @db.VarChar(20)
  joined_at  DateTime @default(now()) @db.Timestamptz(6)

  channel feed_channels   @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profile social_profiles @relation(fields: [user_id],    references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([channel_id, user_id])
  @@schema("public")
}

/// Public channel: user kicked by owner — read-only until owner re-adds them.
model channel_public_removed_members {
  channel_id String   @db.Uuid
  user_id    String   @db.Uuid
  removed_at DateTime @default(now()) @db.Timestamptz(6)

  channel feed_channels   @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profile social_profiles @relation(fields: [user_id],    references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([channel_id, user_id])
  @@index([user_id], map: "idx_channel_public_removed_members_user")
  @@schema("public")
}

/// Invite links for private channels (Discord-style).
model channel_invites {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel_id String    @db.Uuid
  created_by String    @db.Uuid
  token      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label      String?   @db.VarChar(60)
  max_uses   Int?
  use_count  Int       @default(0)
  expires_at DateTime? @db.Timestamptz(6)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  feed_channels feed_channels @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@index([channel_id])
  @@index([token])
  @@map("channel_invites")
  @@schema("public")
}

/// Content moderation reports.
model feed_reports {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_id String   @db.Uuid
  post_id     String?  @db.Uuid
  comment_id  String?  @db.Uuid
  reason      String   @db.VarChar(500)
  status      String   @default("pending") @db.VarChar(20)
  reviewed_by String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  reporter social_profiles @relation(fields: [reporter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  post     feed_posts?     @relation(fields: [post_id],    references: [id], onDelete: Cascade, onUpdate: NoAction)
  comment  feed_comments?  @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status, created_at(sort: Desc)], map: "idx_feed_reports_status")
  @@index([reporter_id], map: "idx_feed_reports_reporter")
  @@schema("public")
}

model reviews {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @unique @db.Uuid
  text        String    @db.VarChar(500)
  rating      Int?      @db.SmallInt
  status      String    @default("pending") @db.VarChar(20)
  reviewed_by String?   @db.Uuid
  reviewed_at DateTime? @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_reviews_status")
  @@index([user_id], map: "idx_reviews_user_id")
  @@schema("public")
}

enum oauth_registration_type {
  dynamic
  manual

  @@schema("auth")
}

enum oauth_response_type {
  code

  @@schema("auth")
}

enum one_time_token_type {
  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token

  @@schema("auth")
}
