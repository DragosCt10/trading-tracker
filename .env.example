# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Direct Postgres connection for Prisma migrations
# Found in: Supabase dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Claude API key (for analyze-trading feature)
NEXT_PUBLIC_CLAUDE_API_KEY=

# Polar billing
POLAR_SANDBOX=true
POLAR_SANDBOX_ACCESS_TOKEN=
POLAR_SANDBOX_WEBHOOK_SECRET=
POLAR_SANDBOX_PRO_PRODUCT_ID_MONTHLY=
POLAR_SANDBOX_PRO_PRODUCT_ID_ANNUAL=
POLAR_SANDBOX_PRO_LEGACY_PRODUCT_ID=

POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID_MONTHLY=
POLAR_PRO_PRODUCT_ID_ANNUAL=
POLAR_PRO_LEGACY_PRODUCT_ID=
